# AIquila MCP Server - Standalone Configuration
# Copy this file to .env and set your Nextcloud connection details.

# =============================
# Nextcloud Connection (REQUIRED)
# =============================

# URL of your external Nextcloud instance
NEXTCLOUD_URL=https://your-nextcloud.example.com

# Nextcloud username
NEXTCLOUD_USER=your-username

# Nextcloud password (app password recommended - see docs/mcp/setup.md)
NEXTCLOUD_PASSWORD=your-app-password

# =============================
# OAuth 2.0 Authentication
# =============================
# Set to true to enable OAuth (required for HTTP-based MCP clients)
MCP_AUTH_ENABLED=false
# Secret key for signing JWTs (generate with: openssl rand -hex 32)
MCP_AUTH_SECRET=
# Public HTTPS URL of this MCP server (e.g. https://mcp.example.com)
MCP_AUTH_ISSUER=

# =============================
# OAuth Client Configuration
# =============================
# Option A — Dynamic registration (recommended for most clients):
#   Set MCP_REGISTRATION_ENABLED=true so any MCP client can self-register.
#   Use MCP_REGISTRATION_TOKEN to restrict who may register.
#
# Option B — Static pre-seeded client (for clients that do not support
#   dynamic registration):
#   Set MCP_CLIENT_ID to a stable identifier for your client, and set
#   MCP_CLIENT_REDIRECT_URIS to the callback URL your client expects.
#   Example redirect URIs:
#     Claude.ai / Claude Code:  https://claude.ai/api/mcp/auth_callback
#     Other clients: check your MCP client's documentation for its callback URL
MCP_CLIENT_ID=
MCP_CLIENT_SECRET=

# Comma-separated redirect URIs for the pre-seeded client (Option B only).
# Leave empty when using dynamic registration (Option A).
MCP_CLIENT_REDIRECT_URIS=

# Dynamic client registration (POST /register) — recommended approach.
# false (default) = only pre-seeded clients above can authenticate.
# true            = any MCP client can self-register (use MCP_REGISTRATION_TOKEN to gate).
MCP_REGISTRATION_ENABLED=false

# When MCP_REGISTRATION_ENABLED=true, require this bearer token on POST /register.
# This is the "SSH authorized_keys" model: operator distributes this token to
# authorized users, each self-registers once to get their own client_id/secret.
# Leave empty to allow open registration.
MCP_REGISTRATION_TOKEN=

# OAuth state persistence — directory for clients.json + refresh-tokens.json
# Mount a Docker volume here (done automatically in docker-compose.yml).
# MCP_AUTH_STATE_DIR=/app/state

# =============================
# Logging
# =============================
# Log level: trace | debug | info | warn | error | fatal  (default: info)
# LOG_LEVEL=info

# =============================
# Reverse Proxy Settings
# =============================
# Set when running behind a reverse proxy (e.g. Traefik, nginx) to prevent
# express-rate-limit from throwing ERR_ERL_UNEXPECTED_X_FORWARDED_FOR.
# Use "1" for a single reverse proxy hop (most common), "true" to trust all proxies.
# MCP_TRUST_PROXY=1

# =============================
# TLS Certificate Validation
# =============================
# When MCP_AUTH_ISSUER is set, the server probes it on startup to verify the
# TLS certificate is CA-signed (not self-signed or expired).
# MCP_TLS_STRICT=true  → hard-fail (exit 1) if cert is invalid
# MCP_TLS_STRICT=false → log error but continue (default)
# MCP_TLS_STRICT=

# =============================
# Production HTTPS
# =============================
# Most MCP clients require a CA-trusted certificate — self-signed certs will not work.
# To enable Let's Encrypt via Caddy:
#   1. Set MCP_DOMAIN to your public FQDN (DNS must point to this server)
#   2. Set ACME_EMAIL for Let's Encrypt renewal notices
#   3. In caddy/Caddyfile: delete the "local_certs" block
#   4. In docker-compose.yml: change caddy ports to "80:80" and "443:443"
#   5. Set MCP_AUTH_ISSUER=https://<MCP_DOMAIN> in the MCP Auth section above
# MCP_DOMAIN=mcp.example.com
# ACME_EMAIL=you@example.com
