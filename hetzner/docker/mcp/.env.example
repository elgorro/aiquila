# AIquila MCP Server — Hetzner Production (MCP-only stack)
# Copy this file to .env and fill in all required values.
# This file is safe to commit (no real secrets).

# ── Nextcloud connection ──────────────────────────────────────────────────────
# URL of your Nextcloud instance (trailing slash is stripped automatically)
NEXTCLOUD_URL=https://nextcloud.example.com

# Nextcloud username (typically your admin account)
NEXTCLOUD_USER=admin

# Nextcloud app password (Settings → Security → App passwords)
NEXTCLOUD_PASSWORD=your-app-password-here

# ── Domain & TLS ──────────────────────────────────────────────────────────────
# FQDN pointing to this server's IP. Traefik obtains a Let's Encrypt cert automatically.
# DNS must be configured BEFORE starting the stack.
MCP_DOMAIN=mcp.example.com

# Internal port the MCP container listens on (Traefik routes to this port)
# Change to 3340 if you need to avoid conflicts with another local service.
MCP_PORT=3339

# Required: email for Let's Encrypt expiry notices (empty string causes LE to reject)
ACME_EMAIL=you@example.com

# ── OAuth 2.0 (required for HTTP-based MCP clients) ──────────────────────────
MCP_AUTH_ENABLED=true

# Random 64-char hex secret — generate with: openssl rand -hex 32
MCP_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Public HTTPS URL of this server (same as https://$MCP_DOMAIN)
MCP_AUTH_ISSUER=https://mcp.example.com

# ── OAuth client configuration ────────────────────────────────────────────────
# Option A — Dynamic registration (recommended): enable below so any MCP client
# can self-register. Gate access with MCP_REGISTRATION_TOKEN if desired.
#
# Option B — Static pre-seeded client: set MCP_CLIENT_ID + MCP_CLIENT_REDIRECT_URIS
# for clients that do not support dynamic registration.
# Example redirect URIs:
#   Claude.ai / Claude Code:  https://claude.ai/api/mcp/auth_callback
#   Other clients: check your MCP client's documentation for its callback URL
MCP_CLIENT_ID=
# Deprecated: MCP_CLIENT_SECRET is no longer used — public PKCE clients do not
# send a client_secret. Keep empty unless you have older deployments that require it.
MCP_CLIENT_SECRET=

# Comma-separated redirect URIs for the pre-seeded client (Option B only).
# Leave empty when using dynamic registration (Option A).
MCP_CLIENT_REDIRECT_URIS=

# ── Dynamic client registration ───────────────────────────────────────────────
# Recommended: set to true so any MCP client can self-register automatically.
MCP_REGISTRATION_ENABLED=false
# Optional bearer token required for registration (leave empty to allow anyone when enabled)
MCP_REGISTRATION_TOKEN=

# OAuth state persistence — directory for clients.json + refresh-tokens.json
# Mount a Docker volume here (done automatically in docker-compose.yml).
# MCP_AUTH_STATE_DIR=/app/state

# ── CrowdSec ──────────────────────────────────────────────────────────────────
# Pre-registered bouncer API key shared between CrowdSec and Traefik.
# Generate with: openssl rand -hex 32
CROWDSEC_BOUNCER_KEY=replace-with-random-hex-32

# ── Monitoring (optional) ──────────────────────────────────────────────────────
# Required only when using --profile monitoring (or aiquila-hetzner --monitoring)
# Grafana admin password — generate with: openssl rand -hex 16
GRAFANA_PASSWORD=replace-with-random
# Start monitoring: docker compose --profile monitoring up -d

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── TLS certificate check ──────────────────────────────────────────────────────
# Hard-fail on startup if MCP_AUTH_ISSUER has a self-signed or expired cert.
# Default is false (log warning but continue) — keeps working during Let's Encrypt init.
# Set to true once the cert is valid and stable.
MCP_TLS_STRICT=false
