# AIquila Nextcloud — Hetzner Production (Nextcloud-only stack)
# Copy this file to .env and fill in all required values.
# This file is safe to commit (no real secrets).

# ── Domain & TLS ──────────────────────────────────────────────────────────────
# FQDN pointing to this server's IP. Traefik obtains a Let's Encrypt cert automatically.
# DNS must be configured BEFORE starting the stack.
NC_DOMAIN=nc.example.com

# Required: email for Let's Encrypt expiry notices (empty string causes LE to reject)
ACME_EMAIL=you@example.com

# ── Nextcloud admin account ────────────────────────────────────────────────────
# Created on first boot. Use strong passwords.
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=replace-with-strong-password

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Internal database password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-random-hex-32

# ── CrowdSec ──────────────────────────────────────────────────────────────────
# Pre-registered bouncer API key shared between CrowdSec and Traefik.
# Generate with: openssl rand -hex 32
CROWDSEC_BOUNCER_KEY=replace-with-random-hex-32

# ── NC33 Metrics ───────────────────────────────────────────────────────────────
# Token for the built-in NC33 metrics app endpoint: https://<NC_DOMAIN>/metrics?token=<value>
# Leave empty to disable, or generate with: openssl rand -hex 16
NC_METRICS_TOKEN=
