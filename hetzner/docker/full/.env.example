# AIquila Full Stack — Hetzner Production (Nextcloud + MCP on one server)
# Copy this file to .env and fill in all required values.
# This file is safe to commit (no real secrets).

# ── Nextcloud domain ──────────────────────────────────────────────────────────
NC_DOMAIN=nc.example.com

# ── MCP domain ────────────────────────────────────────────────────────────────
MCP_DOMAIN=mcp.example.com

# Optional: email for Let's Encrypt expiry notices (leave empty to skip)
ACME_EMAIL=

# ── Nextcloud admin account ────────────────────────────────────────────────────
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=replace-with-strong-password

# ── Nextcloud user for MCP (app password created via OCC at provisioning) ─────
NC_MCP_USER=admin
NC_MCP_PASSWORD=replace-with-app-password

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-random-hex-32

# ── OAuth 2.0 (required for Claude.ai remote MCP) ────────────────────────────
MCP_AUTH_ENABLED=true

# Random 64-char hex secret — generate with: openssl rand -hex 32
MCP_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Public HTTPS URL of the MCP server (same as https://$MCP_DOMAIN)
MCP_AUTH_ISSUER=https://mcp.example.com

# OAuth client credentials
MCP_CLIENT_ID=aiquila-claude
# Random 64-char hex secret — generate with: openssl rand -hex 32
MCP_CLIENT_SECRET=replace-with-openssl-rand-hex-32

# Comma-separated redirect URIs allowed for the pre-seeded OAuth client
# (https://claude.ai/api/mcp/auth_callback is required for Claude Code / Claude.ai)
MCP_CLIENT_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# ── Dynamic client registration ───────────────────────────────────────────────
MCP_REGISTRATION_ENABLED=true
MCP_REGISTRATION_TOKEN=

# ── Proxy ─────────────────────────────────────────────────────────────────────
MCP_TRUST_PROXY=true

# ── CrowdSec ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CROWDSEC_BOUNCER_KEY=replace-with-random-hex-32

# ── NC33 Metrics ───────────────────────────────────────────────────────────────
# Token for the built-in NC33 metrics app endpoint: https://<NC_DOMAIN>/metrics?token=<value>
# Leave empty to disable, or generate with: openssl rand -hex 16
NC_METRICS_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
