{
  "name": "aiquila-mcp",
  "version": "0.3.7",
  "description": "AIquila - MCP server for Nextcloud integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aiquila-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node scripts/sync-server-json.mjs && (tsc --noCheck || tsc)",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:cli": "npx @modelcontextprotocol/inspector --cli node dist/index.js --method tools/list"
  },
  "keywords": [
    "mcp",
    "nextcloud",
    "claude",
    "ai",
    "aiquila"
  ],
  "author": "sirgorro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elgorro/aiquila.git"
  },
  "mcpName": "io.github.elgorro/aiquila-mcp",
  "files": [
    "dist/"
  ],
  "overrides": {
    "brace-expansion": "^2.0.3",
    "hono": "^4.12.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "typescript": "^5.8.3",
    "webdav": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
