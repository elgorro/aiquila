{
  "name": "aiquila-mcp",
  "version": "0.3.30",
  "description": "Nextcloud MCP server — files, calendar, contacts, mail, maps, notes, tasks & 120+ more tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aiquila-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node scripts/sync-server-json.mjs && (tsc --noCheck || tsc)",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:cli": "npx @modelcontextprotocol/inspector --cli node dist/index.js --method tools/list"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nextcloud",
    "claude",
    "ai",
    "aiquila",
    "webdav",
    "caldav",
    "carddav",
    "self-hosted"
  ],
  "author": "sirgorro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elgorro/aiquila.git"
  },
  "mcpName": "io.github.elgorro/aiquila-mcp",
  "files": [
    "dist/"
  ],
  "overrides": {
    "brace-expansion": "^2.0.3",
    "esbuild": ">=0.28.1",
    "hono": "^4.12.14"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "typescript": "^5.9.3",
    "webdav": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
